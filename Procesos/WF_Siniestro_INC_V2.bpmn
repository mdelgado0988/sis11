    <bpmn2:scriptTask id="Task_18d44ci" name="Notificación por correo a ajustador" userActions="[]">
      <bpmn2:incoming>SequenceFlow_0p10mv6</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_14g7mls</bpmn2:outgoing>
      <bpmn2:script>{cmd:"ExeChain",data:{chain:"cmdEnvioCorreoAjustadorInspectorReclamoINC", context:"{row:{reclamo:#entity.id#, proceso: #self.id#}}"}};</bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:exclusiveGateway id="ExclusiveGateway_1518wpz" condicion="//block&#10;&#10;&#10;doCmd({&#10;    cmd: &#34;LoadEntity&#34;,&#10;    data: {&#10;      entity: &#34;LifeCoveragePayout&#34;,&#10;      fields: &#34;COUNT(1) pagos&#34;,&#10;      filter: `claimId = ${_entity.id} AND payed &#60;&#62; 0 AND status &#60;&#62; 2`&#10;    }&#10;  })&#10;&#10;const resultado = LoadEntity?.outData.pagos ?? 0;&#10;&#10;return resultado == 0 ? &#34;No&#34; : &#34;Si&#34;" userActions="[]">
