    <bpmn2:task id="Task_0wyzdfc" name="Valoracion" userActions="[]" clientScript="this.exe(&#34;ExeChain&#34;, {&#10;  chain: &#34;cmdRequiereRevisionReaseguro&#34;,&#10;  context: `{ id: ${this.process.entityId}}`&#10;})&#10;.then(mOutData =&#62; {&#10;  const resultado = mOutData?.outData ?? &#34;&#34;;&#10;console.log(resultado)&#10;log(&#39;Resultado del comando cmdRequiereRevisionReaseguro:&#39;);&#10;  if (resultado ==&#39; Si&#39;) {&#10;    log(&#39;Cumple&#39;)&#10;    // Si cumple, enviar correo&#10;    this.exe(&#34;ExeChain&#34;, {&#10;      chain: &#34;cmdEnvioCorreoReaseguroReclamoINC&#34;,&#10;      context: `{ row: { reclamo: ${this.process.entityId} } }`&#10;    });&#10;  } &#10;});">
      <bpmn2:incoming>SequenceFlow_14g7mls</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_057uqqs</bpmn2:outgoing>
